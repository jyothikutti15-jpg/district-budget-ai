# ============================================================
# AI DISTRICT BUDGET PLANNER — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to Git
# ============================================================

# ─── Supabase (get both from supabase.com → Settings → API) ──
# These replace the old DATABASE_URL + Google OAuth
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...  (Settings → API → service_role key — KEEP SECRET)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-ID.supabase.co:5432/postgres

# Frontend Supabase keys (safe to expose — these are public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...  (Settings → API → anon/public key)

# ─── AI ──────────────────────────────────────────────────────
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Auth ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-string

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── NO GOOGLE OAUTH NEEDED ──────────────────────────────────
# Login is handled by Supabase email/password
# Delete these lines if you copied from an older .env:
# GOOGLE_CLIENT_ID=    ← NOT NEEDED
# GOOGLE_CLIENT_SECRET= ← NOT NEEDED
